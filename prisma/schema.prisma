generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["views"]
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}

model alimente {
  idcompteur String   @db.VarChar(50)
  idpiece    String   @db.VarChar(80)
  compteur   compteur @relation(fields: [idcompteur], references: [idcompteur], onDelete: Cascade)
  piece      piece    @relation(fields: [idpiece], references: [idpiece], onDelete: Cascade)

  @@id([idcompteur, idpiece])
  @@index([idcompteur], map: "_alimente__index_idcompteur")
  @@index([idpiece], map: "_alimente__index_idpiece")
  @@map("_alimente")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model batiment {
  idbat           String         @id @db.VarChar(80)
  nombat          String         @db.VarChar(100)
  longitude       Float
  latitude        Float
  nomvoie         String         @db.VarChar(200)
  cmpltadresse    String?        @db.VarChar(200)
  idsite          String         @db.VarChar(80)
  anneecref       Int?
  idsmplr         String?        @db.VarChar(50)
  datecreauib     DateTime       @default(dbgenerated("timezone('Europe/Paris'::text, CURRENT_TIMESTAMP)")) @db.Timestamp(6)
  mixte           Boolean        @default(false)
  surfacecommune  Float          @default(0)
  codefacturation String?        @db.VarChar(80)
  site            site           @relation(fields: [idsite], references: [idsite], onDelete: Cascade)
  gerebat         gerebat[]
  intervention    intervention[]
  lot             lot[]
  repartition     repartition[]

  @@index([nomvoie], map: "_batiment__index_adresse")
  @@index([idbat], map: "_batiment__index_idbat")
  @@index([nombat], map: "_batiment__index_nombat")
  @@map("_batiment")
}

model batterie {
  idbatterie  String        @id @db.VarChar(64)
  nombatterie String        @db.VarChar(120)
  voltage     Float
  modele      modele[]
  secomposede secomposede[]

  @@map("_batterie")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model cabs {
  codescap       String @db.VarChar(10)
  cvcetalon      Float
  useetalon      Float
  decennie       String @db.Char(9)
  zonesref       String @db.VarChar(15)
  altituderefmax Float
  altituderefmin Float
  scap           scap   @relation(fields: [codescap], references: [codescap], onDelete: Cascade)

  @@id([codescap, decennie, zonesref, altituderefmax, altituderefmin])
  @@map("_cabs")
}

model cap {
  codeactivite String @id @db.VarChar(7)
  nomactivite  String @db.VarChar(300)
