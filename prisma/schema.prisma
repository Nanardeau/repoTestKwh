  @@map("_cap")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model capteur {
  deveui              String               @id @db.VarChar(16)
  appkey              String?              @db.Char(32)
  datearrivee         DateTime             @default(dbgenerated("timezone('Europe/Paris'::text, CURRENT_TIMESTAMP)")) @db.Timestamp(6)
  idcommande          String?              @db.VarChar(16)
  esthorsservice      Boolean              @default(false)
  etat                String               @default("FONCTIONNEL") @db.VarChar(15)
  idelement           Int?
  referenceinterne    String?              @db.VarChar(50)
  commandefournisseur commandefournisseur? @relation(fields: [idcommande], references: [idfacture], onDelete: Cascade)
  elements            elements?            @relation(fields: [idelement], references: [idelement], onDelete: NoAction)
  modele              modele?              @relation(fields: [referenceinterne], references: [referenceinterne], onDelete: Cascade)
  estlie              estlie[]
  intervention        intervention[]
  reglage             reglage[]

  @@index([datearrivee], map: "_capteur__index_datearrivee")
  @@index([deveui], map: "_capteur__index_deveui")
  @@index([referenceinterne], map: "_capteur__index_referenceinterne")
  @@map("_capteur")
}

